# 데이터베이스
DATABASE_URL=sqlite:///./data/labeling.db

# SAM 모델 체크포인트 절대경로
SAM_CHECKPOINT_PATH=/absolute/path/to/sam2.1_hiera_large.pt
SAM_MODEL_CFG=sam2.1_hiera_l.yaml

# 환경 (dev | prod)
APP_ENV=dev

# 시드 설정 파일 경로 (dev: labeling.dev.yaml, prod: labeling.prod.yaml)
LABELING_CONFIG_PATH=config/labeling.dev.yaml

# 테넌트 기본값 (단일 운영 시)
DEFAULT_TENANT_ID=default
