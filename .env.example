# 데이터베이스
DATABASE_URL=sqlite:///./data/labeling.db

# SAM 모델 체크포인트 절대경로 (Windows 예: C:/path/to/repo/models/sam2.1_hiera_base_plus.pt)
# 받기: uv run python scripts/download_sam_checkpoint.py --variant hiera_base
# large: --variant hiera_large → sam2.1_hiera_large.pt + SAM_MODEL_CFG=sam2.1_hiera_l.yaml
SAM_CHECKPOINT_PATH=/absolute/path/to/sam2.1_hiera_base_plus.pt
SAM_MODEL_CFG=sam2.1_hiera_b+.yaml

# SAM 타일 임베딩 LRU 슬롯 수 (동시에 다른 타일을 쓰는 라벨러 수에 맞춰 4~8 권장)
# SAM_EMBEDDING_CACHE_MAX=4

# 환경 (dev | prod) — dev 일 때 백엔드 로그 레벨이 DEBUG
APP_ENV=dev

# 시드 설정 YAML (프로젝트 루트 기준 상대경로 권장)
#   개발: config/labeling.dev.yaml
#   운영: config/labeling.prod.yaml  (APP_ENV=prod 일 때 이쪽을 가리키도록 .env 분리 권장)
LABELING_CONFIG_PATH=config/labeling.dev.yaml

# 테넌트 기본값 (단일 운영 시)
DEFAULT_TENANT_ID=default
