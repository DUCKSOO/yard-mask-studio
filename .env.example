# 데이터베이스
DATABASE_URL=sqlite:///./data/labeling.db

# SAM 모델 체크포인트 절대경로 (예: models/sam2.1_hiera_large.pt — 받기: uv run python scripts/download_sam_checkpoint.py --variant hiera_large)
SAM_CHECKPOINT_PATH=/absolute/path/to/sam2.1_hiera_large.pt
SAM_MODEL_CFG=sam2.1_hiera_l.yaml

# 환경 (dev | prod)
APP_ENV=dev

# 시드 설정 YAML (프로젝트 루트 기준 상대경로 권장)
#   개발: config/labeling.dev.yaml
#   운영: config/labeling.prod.yaml  (APP_ENV=prod 일 때 이쪽을 가리키도록 .env 분리 권장)
LABELING_CONFIG_PATH=config/labeling.dev.yaml

# 테넌트 기본값 (단일 운영 시)
DEFAULT_TENANT_ID=default
