# 프론트엔드 환경 (Vite)
# 이 파일을 복사해 frontend/.env 로 두고 값을 맞춥니다.

# 백엔드 API 베이스 URL (비우면 동일 오리진 프록시 사용)
VITE_API_BASE_URL=http://127.0.0.1:8000

# dev: 콘솔에 debug/info 로그 출력 (logger.ts, Axios 인터셉터)
# prod 빌드에서는 보통 prod 로 두어 불필요한 로그를 줄입니다.
VITE_APP_ENV=dev

# 선택: 앱 기본 tenant / dataset (App.tsx 기본값)
# VITE_TENANT_ID=default
# VITE_DATASET_ID=step3_e2e
